{
  "name": "@pawells/nestjs-pyroscope",
  "displayName": "@pawells/nestjs-pyroscope",
  "version": "1.1.2",
  "description": "NestJS Pyroscope profiling with decorators and interceptors",
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "require": "./build/index.js",
      "import": "./build/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "pipeline": "yarn typecheck && yarn lint && yarn test && yarn build"
  },
  "peerDependencies": {
    "@nestjs/common": ">=10.0.0",
    "@nestjs/core": ">=10.0.0",
    "@nestjs/terminus": ">=10.0.0",
    "rxjs": ">=7.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/terminus": "^11.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "dependencies": {
    "@pyroscope/nodejs": "^0.4.10"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@4.12.0",
  "author": "Aaron Wells <69355326+PhillipAWells@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/PhillipAWells/nestjs-common"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
