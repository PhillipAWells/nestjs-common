# JWT
# Required. Minimum 32 characters.
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars
# Token expiry duration. Format: <number><unit> where unit is s, m, h, or d. Default: 15m.
JWT_EXPIRES_IN=15m
# JWT issuer claim. Default: nestjs-app.
JWT_ISSUER=nestjs-app
# JWT audience claim. Default: nestjs-api.
JWT_AUDIENCE=nestjs-api

# Keycloak OAuth2 (required if using KeycloakStrategy)
KEYCLOAK_AUTH_URL=https://keycloak.example.com/realms/myrealm/protocol/openid-connect/auth
KEYCLOAK_TOKEN_URL=https://keycloak.example.com/realms/myrealm/protocol/openid-connect/token
KEYCLOAK_CLIENT_ID=my-client
KEYCLOAK_CLIENT_SECRET=replace-with-keycloak-client-secret
# Must be HTTPS in production.
KEYCLOAK_CALLBACK_URL=https://api.example.com/auth/keycloak/callback

# Keycloak Admin API (optional)
# Set to "true" to enable the Keycloak admin client. Default: false.
KEYCLOAK_ENABLED=false
KEYCLOAK_SERVER_URL=https://keycloak.example.com
KEYCLOAK_REALM=myrealm
KEYCLOAK_USERNAME=admin
KEYCLOAK_PASSWORD=replace-with-keycloak-admin-password

# Generic OIDC (required if using OIDCStrategy)
OIDC_ISSUER=https://idp.example.com
OIDC_AUTHORIZATION_URL=https://idp.example.com/oauth2/authorize
OIDC_TOKEN_URL=https://idp.example.com/oauth2/token
OIDC_USERINFO_URL=https://idp.example.com/oauth2/userinfo
OIDC_CLIENT_ID=my-client
OIDC_CLIENT_SECRET=replace-with-oidc-client-secret
# Must be HTTPS in production.
OIDC_CALLBACK_URL=https://api.example.com/auth/oidc/callback

# Generic OAuth2 (optional)
OAUTH2_AUTHORIZATION_URL=https://provider.example.com/oauth2/authorize
OAUTH2_TOKEN_URL=https://provider.example.com/oauth2/token
OAUTH2_CLIENT_ID=my-client
OAUTH2_CLIENT_SECRET=replace-with-oauth2-client-secret
# Must be HTTPS in production.
OAUTH2_CALLBACK_URL=https://api.example.com/auth/oauth2/callback

# Default OAuth provider fallback. Default: keycloak.
OAUTH_DEFAULT_PROVIDER=keycloak
