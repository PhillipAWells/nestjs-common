# Application
NODE_ENV=development

# CSRF Protection
# Required. Minimum 32 characters, high entropy (no repeated chars or common patterns).
CSRF_SECRET=replace-with-a-strong-random-secret-min-32-chars

# Metrics
# Set to "false" to disable metrics collection. Default: true.
METRICS_ENABLED=true

# HTTP Client Timeout (milliseconds). Default: 30000.
HTTP_CLIENT_TIMEOUT=30000

# Config Validation Timeout (milliseconds). Default: 3000.
CONFIG_VALIDATION_TIMEOUT=3000

# External Service Timeouts (milliseconds). Defaults: 1000.
GRAFANA_TIMEOUT=1000
LOKI_TIMEOUT=1000
PROMETHEUS_TIMEOUT=1000
