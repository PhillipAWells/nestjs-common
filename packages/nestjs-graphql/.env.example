# Redis (used for caching and pub/sub subscriptions)
# Default: localhost
REDIS_HOST=localhost
# Default: 6379
REDIS_PORT=6379
# Optional. Minimum 8 characters if set.
REDIS_PASSWORD=
# Redis database index (0–15). Default: 0.
REDIS_DB=0
# Key prefix for namespacing. Default: empty.
REDIS_KEY_PREFIX=
# Maximum connection retry attempts. Default: 3.
REDIS_MAX_RETRIES=3
# Connection timeout (milliseconds). Default: 10000.
REDIS_CONNECT_TIMEOUT=10000
# Command execution timeout (milliseconds). Default: 5000.
REDIS_COMMAND_TIMEOUT=5000
# IP protocol family: 4 (IPv4) or 6 (IPv6). Default: 4.
REDIS_FAMILY=4
# Keep-alive probe interval (milliseconds). Default: 30000.
REDIS_KEEP_ALIVE=30000
# Delay between retry attempts (milliseconds). Default: 100.
REDIS_RETRY_DELAY=100
# Check Redis readiness before sending commands. Default: true.
REDIS_ENABLE_READY_CHECK=true
# Defer connection until first command. Default: false.
REDIS_LAZY_CONNECT=false
# Cache entry time-to-live (seconds). Default: 3600.
REDIS_CACHE_TTL=3600
