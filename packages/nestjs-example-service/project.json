{
	"name": "nestjs-example-service",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"sourceRoot": "packages/nestjs-example-service/src",
	"projectType": "application",
	"targets": {
		"build": {
			"executor": "nx:run-commands",
			"options": {
				"command": "tsc --project tsconfig.build.json",
				"cwd": "{projectRoot}"
			},
			"outputs": ["{projectRoot}/build"]
		},
		"typecheck": {
			"executor": "nx:run-commands",
			"options": {
				"command": "tsc --noEmit",
				"cwd": "{projectRoot}"
			}
		},
		"lint": {
			"executor": "@nx/eslint:lint",
			"outputs": ["{options.outputFile}"],
			"options": {
				"lintFilePatterns": ["{projectRoot}/src/**/*.ts"]
			}
		},
		"test": {
			"executor": "nx:run-commands",
			"options": {
				"command": "vitest run",
				"cwd": "{projectRoot}"
			}
		}
	}
}
