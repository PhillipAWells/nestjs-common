{
  "name": "nestjs-example-service",
  "displayName": "nestjs-example-service",
  "private": true,
  "version": "1.0.2",
  "description": "Example NestJS service demonstrating usage of all @pawells/nestjs-* packages. Not published.",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "serve": "nx serve nestjs-example-service",
    "pipeline": "yarn typecheck && yarn lint && yarn test && yarn build"
  },
  "dependencies": {
    "@apollo/server": "^4.0.0",
    "@nestjs/apollo": ">=12.0.0",
    "@nestjs/cache-manager": ">=2.0.0",
    "@nestjs/common": ">=10.0.0",
    "@nestjs/config": ">=3.0.0",
    "@nestjs/core": ">=10.0.0",
    "@nestjs/graphql": ">=12.0.0",
    "@nestjs/jwt": ">=10.0.0",
    "@nestjs/passport": ">=10.0.0",
    "@nestjs/terminus": ">=10.0.0",
    "@nestjs/throttler": ">=5.0.0",
    "@opentelemetry/api": ">=1.0.0",
    "@pawells/nestjs-auth": "workspace:*",
    "@pawells/nestjs-graphql": "workspace:*",
    "@pawells/nestjs-open-telemetry": "workspace:*",
    "@pawells/nestjs-prometheus": "workspace:*",
    "@pawells/nestjs-pyroscope": "workspace:*",
    "@pawells/nestjs-qdrant": "workspace:*",
    "@pawells/nestjs-shared": "workspace:*",
    "@qdrant/js-client-rest": ">=1.0.0",
    "cache-manager": ">=5.0.0",
    "class-transformer": ">=0.5.0",
    "class-validator": ">=0.14.0",
    "compression": ">=1.0.0",
    "csrf-csrf": ">=3.0.0",
    "dataloader": ">=2.0.0",
    "express": ">=4.0.0",
    "graphql": ">=16.0.0",
    "graphql-query-complexity": ">=0.12.0",
    "graphql-redis-subscriptions": ">=2.0.0",
    "graphql-subscriptions": "^3.0.0",
    "helmet": ">=7.0.0",
    "ioredis": ">=5.0.0",
    "joi": ">=17.0.0",
    "keyv": "^4.5.4",
    "passport": "^0.7.0",
    "prom-client": ">=15.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": ">=7.0.0",
    "typescript": "^5.3.3",
    "uuid": ">=9.0.0",
    "xss": ">=1.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@4.12.0",
  "author": "Aaron Wells <69355326+PhillipAWells@users.noreply.github.com>",
  "license": "MIT"
}
