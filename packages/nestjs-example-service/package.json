{
  "name": "nestjs-example-service",
  "displayName": "nestjs-example-service",
  "private": true,
  "version": "1.1.2",
  "description": "Example NestJS service demonstrating usage of all @pawells/nestjs-* packages. Not published.",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "serve": "nx serve nestjs-example-service",
    "pipeline": "yarn typecheck && yarn lint && yarn test && yarn build"
  },
  "dependencies": {
    "@nestjs/common": ">=11.1.17",
    "@nestjs/config": ">=4.0.3",
    "@nestjs/core": ">=11.1.17",
    "@nestjs/jwt": ">=11.0.2",
    "@nestjs/passport": ">=11.0.5",
    "@nestjs/terminus": ">=11.1.1",
    "@nestjs/throttler": ">=6.5.0",
    "@opentelemetry/api": ">=1.9.1",
    "@pawells/nestjs-auth": "workspace:*",
    "@pawells/nestjs-open-telemetry": "workspace:*",
    "@pawells/nestjs-prometheus": "workspace:*",
    "@pawells/nestjs-pyroscope": "workspace:*",
    "@pawells/nestjs-qdrant": "workspace:*",
    "@pawells/nestjs-shared": "workspace:*",
    "@qdrant/js-client-rest": ">=1.17.0",
    "class-transformer": ">=0.5.1",
    "class-validator": ">=0.15.1",
    "compression": ">=1.8.1",
    "csrf-csrf": ">=4.0.3",
    "express": ">=5.2.1",
    "helmet": ">=8.1.0",
    "joi": ">=18.1.2",
    "passport": "^0.7.0",
    "prom-client": ">=15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": ">=7.8.2",
    "typescript": "^6.0.2",
    "xss": ">=1.0.15"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "yarn@4.12.0",
  "author": "Aaron Wells <69355326+PhillipAWells@users.noreply.github.com>",
  "license": "MIT"
}
